# Environment variables consumed by netlify/functions/submit-lead.js
#
# Copy this file to .env (gitignored) for local development with `netlify dev`,
# or set each value in Netlify → Site settings → Build & deploy → Environment.
# All are optional — the function validates payloads and returns 200 / 400
# correctly even with nothing set, it just doesn't forward leads anywhere.
#
# DO NOT commit a populated .env file. The .gitignore (PR #74) blocks it
# by default; double-check if you ever bypass it.

# ─── Webhook for Google Sheets / email pipeline ──────────────────────────
# POST destination for real lead JSON. Typically a Google Apps Script
# web-app deployed as "Anyone, even anonymous".
LEAD_WEBHOOK_URL=

# Separate sink for spam-blocked submissions (honeypot, rate-limit,
# disposable email, etc.). If empty, blocked records fall through to
# LEAD_WEBHOOK_URL with is_spam:true.
LEAD_SPAM_WEBHOOK_URL=

# ─── Google reCAPTCHA v3 ─────────────────────────────────────────────────
# Site key lives in js/recaptcha-helper.js (public).
# Secret key gates server-side enforcement: when set, every submission
# without a token gets silently 200'd as spam.
RECAPTCHA_SECRET=

# ─── Twilio WhatsApp Business API ────────────────────────────────────────
# All four required for WhatsApp lead notifications to fire.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_TO=whatsapp:+6581881488

# Optional approved Meta template SIDs per lead category. If omitted, the
# function falls back to plain-text WhatsApp body (still works, but the
# template is the official path).
TWILIO_NEW_LAUNCH_CONTENT_SID=
TWILIO_SELLER_LANDLORD_CONTENT_SID=
TWILIO_VALUATION_CONTENT_SID=
